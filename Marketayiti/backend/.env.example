# ════════════════════════════════════════════════════════════════════════════════
# AyitiMarket — Environment template (copy to .env, NEVER commit .env)
# Generate JWT secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ════════════════════════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=AyitiMarket
APP_ENV=development
PORT=4000

# ── JWT — REQUIRED: generate with crypto.randomBytes(64).toString('hex') ─────
# Both must be different 64-byte hex strings. Server refuses to start if missing/short.
JWT_SECRET=CHANGE_ME_generate_64_byte_hex_here
JWT_REFRESH_SECRET=CHANGE_ME_generate_different_64_byte_hex_here
ACCESS_TOKEN_EXPIRE=2h
REFRESH_TOKEN_EXPIRE=30d

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_PATH=./data/ayiti_market.db
# Prod PostgreSQL:
# DATABASE_URL=postgresql://user:pass@localhost:5432/ayitimarket
# USE_PRISMA=true

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Admin bootstrap ───────────────────────────────────────────────────────────
# ADMIN_PASSWORD is REQUIRED. In production: min 12 chars, strong password.
ADMIN_EMAIL=admin@ayitimarket.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# ── Rate limits ───────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=500
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20

# ── SMTP (Gmail App Password) ─────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=AyitiMarket <your@gmail.com>

# ── Frontend URL (used in email links) ───────────────────────────────────────
APP_URL=http://localhost:3000

# ── Polymarket sync ───────────────────────────────────────────────────────────
POLYMARKET_MOCK=true
POLYMARKET_FAST_INTERVAL_MS=30000
POLYMARKET_SLOW_INTERVAL_MS=300000
NEW_MARKET_INTERVAL_MS=180000
