# App
APP_NAME=AyitiMarket
APP_ENV=development
PORT=4000

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=ayitimarket-development-secret-change-in-production-please-do-it-now-okay
JWT_REFRESH_SECRET=ayitimarket-refresh-secret-change-in-production-please-do-it-now-okay
ACCESS_TOKEN_EXPIRE=2h
REFRESH_TOKEN_EXPIRE=30d

# Database
# Dev: sql.js (file-based, zero compilation). Set DATABASE_PATH.
# Prod: PostgreSQL via Prisma. Set DATABASE_URL & USE_PRISMA=true.
DATABASE_PATH=./data/ayiti_market.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/ayitimarket
# USE_PRISMA=true

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://172.20.10.2:3000


# Admin bootstrap
ADMIN_EMAIL=admin@ayitimarket.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin2024!

# Rate limits
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=500
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=50
